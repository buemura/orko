{
  "events": [
    {
      "type": "OrderCreated",
      "handler": "handlers/OrderCreated/handler.ts"
    },
    {
      "type": "OrderCanceled",
      "handler": "handlers/OrderCanceled/handler.ts"
    },
    {
      "type": "PaymentRequested",
      "handler": "handlers/PaymentRequested/handler.ts"
    },
    {
      "type": "PaymentCompleted",
      "handler": "handlers/PaymentCompleted/handler.ts"
    },
    {
      "type": "StockUpdate",
      "handler": "handlers/StockUpdate/handler.ts"
    }
  ],
  "workflows": [
    {
      "name": "ProcessOrder",
      "steps": [
        {
          "type": "OrderCreated",
          "action": "CreateOrder"
        },
        {
          "type": "StockUpdate",
          "action": "ReduceStock"
        },
        {
          "type": "PaymentRequested",
          "action": "ProcessPayment"
        },
        {
          "type": "PaymentCompleted",
          "action": "CompleteOrder"
        }
      ]
    }
  ]
}
